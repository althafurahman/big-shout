  "types": [
    {
      "name": "Config",
      "docs": [
        "One-time program config. The admin (the operator's service wallet) is the",
        "only key that may create markets or move odds — the operator is a trusted",
        "market-maker. Settlement is NOT restricted: any key with a valid TxLINE",
        "proof (or an expired deadline) can settle, so the operator is an",
        "untrusted settler."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "admin",
            "type": "pubkey"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "Market",
      "docs": [
        "A binary fixed-odds micro-market over one provable TxLINE stat:",
        "\"will `stat_key` exceed `threshold` before `deadline_ts`?\""
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "market_id",
            "docs": [
              "Operator-assigned unique id; PDA seed. Card copy (\"will this corner",
              "become a goal?\") lives off-chain keyed by this id — on-chain only the",
              "provable predicate matters."
            ],
            "type": "u64"
          },
          {
            "name": "fixture_id",
            "docs": [
              "TxLINE fixture id this market observes."
            ],
            "type": "i64"
          },
          {
            "name": "stat_key",
            "docs": [
              "TxLINE stat key (`period_prefix + base_key`) the proof must contain."
            ],
            "type": "u32"
          },
          {
            "name": "threshold",
            "docs": [
              "YES wins when the oracle proves `stat value > threshold` in a record",
              "timestamped at/before `deadline_ts`."
            ],
            "type": "i32"
          },
          {
            "name": "created_ts",
            "type": "i64"
          },
          {
            "name": "deadline_ts",
            "docs": [
              "Unix seconds. Predictions rejected at/after this time; a settlement",
              "proof's record timestamp must be at/before it."
            ],
            "type": "i64"
          },
          {
            "name": "yes_odds_bps",
            "docs": [
              "Current decimal odds in bps for each side. Snapshotted onto the",
              "Position at lock time — players win at the price they took."
            ],
            "type": "u32"
          },
          {
            "name": "no_odds_bps",
            "type": "u32"
          },
          {
            "name": "status",
            "type": {
              "defined": {
                "name": "MarketStatus"
              }
            }
          },
          {
            "name": "settled_proof_ts",
            "docs": [
              "TxLINE record timestamp (ms) of the proof used to settle YES."
            ],
            "type": "i64"
          },
          {
            "name": "yes_count",
            "docs": [
              "Live consensus tallies, readable by anyone (the consensus reveal and",
              "the sentiment dataset are views over these)."
            ],
            "type": "u32"
          },
          {
            "name": "no_count",
            "type": "u32"
          },
          {
            "name": "yes_staked",
            "type": "u64"
          },
          {
            "name": "no_staked",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "MarketStatus",
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Open"
          },
          {
            "name": "YesWon"
          },
          {
            "name": "NoWon"
          }
        ]
      }
    },
    {
      "name": "Player",
      "docs": [
        "Per-player points and reputation. Points are a plain u64: free,",
        "non-cashable, non-transferable — a scorekeeping system, not a treasury."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "type": "pubkey"
          },
          {
            "name": "points",
            "type": "u64"
          },
          {
            "name": "last_refill_ts",
            "docs": [
              "Start of the last UTC day the daily allowance was topped up."
            ],
            "type": "i64"
          },
          {
            "name": "streak",
            "type": "u16"
          },
          {
            "name": "best_streak",
            "type": "u16"
          },
          {
            "name": "correct",
            "type": "u32"
          },
          {
            "name": "total",
            "type": "u32"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "Position",
      "docs": [
        "One player's sealed call on one market. Persists forever after claim —",
        "this account IS the receipt: what you said, when you locked it, at what",
        "odds, and how it settled."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "market",
            "type": "pubkey"
          },
          {
            "name": "user",
            "docs": [
              "The player's wallet (Player PDA authority), not the fee payer."
            ],
            "type": "pubkey"
          },
          {
            "name": "side",
            "docs": [
              "true = YES, false = NO."
            ],
            "type": "bool"
          },
          {
            "name": "amount",
            "docs": [
              "Points staked."
            ],
            "type": "u64"
          },
          {
            "name": "odds_bps",
            "docs": [
              "Decimal odds (bps) snapshotted from the market at lock time."
            ],
            "type": "u32"
          },
          {
            "name": "locked_ts",
            "docs": [
              "Unix seconds when the call was sealed — before the outcome was known."
            ],
            "type": "i64"
          },
          {
            "name": "claimed",
            "type": "bool"
          },
          {
            "name": "won",
            "docs": [
              "Set at claim; lets indexers read outcomes without joining the market."
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ProofNode",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "hash",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "is_right_sibling",
            "type": "bool"
          }
        ]
      }
    },
    {
      "name": "ScoreStat",
      "docs": [
        "The on-chain representation of a single, provable key-value statistic.",
        "This is the leaf of the inner-most Merkle tree."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "key",
            "type": "u32"
          },
          {
            "name": "value",
            "type": "i32"
          },
          {
            "name": "period",
            "type": "i32"
          }
        ]
      }
    },
    {
      "name": "ScoresBatchSummary",
      "docs": [
        "The summary for a single fixture's scores events within a 5-minute batch.",
        "This contains the root of the sub-tree of all events for that fixture."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "fixture_id",
            "type": "i64"
          },
          {
            "name": "update_stats",
            "type": {
              "defined": {
                "name": "ScoresUpdateStats"
              }
            }
          },
          {
            "name": "events_sub_tree_root",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    },
    {
      "name": "ScoresUpdateStats",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "update_count",
            "type": "i32"
          },
          {
            "name": "min_timestamp",
            "type": "i64"
          },
          {
            "name": "max_timestamp",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "StatLeaf",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "stat",
            "type": {
              "defined": {
                "name": "ScoreStat"
              }
            }
          },
          {
            "name": "stat_proof",
            "type": {
              "vec": {
                "defined": {
                  "name": "ProofNode"
                }
              }
            }
          }
        ]
      }
    },
    {
      "name": "StatValidationInput",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "ts",
            "type": "i64"
          },
          {
            "name": "fixture_summary",
            "type": {
              "defined": {
                "name": "ScoresBatchSummary"
              }
            }
          },
          {
            "name": "fixture_proof",
            "type": {
              "vec": {
                "defined": {
                  "name": "ProofNode"
                }
              }
            }
          },
          {
            "name": "main_tree_proof",
            "type": {
              "vec": {
                "defined": {
                  "name": "ProofNode"
                }
              }
            }
          },
          {
            "name": "event_stat_root",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "stats",
            "type": {
              "vec": {
                "defined": {
                  "name": "StatLeaf"
                }
              }
            }
          }
        ]
      }
    }
  ]
