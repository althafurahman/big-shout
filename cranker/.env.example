# One config object, one network — never mix hosts/programs/RPC across networks.
TX_NETWORK=devnet

# Activated TxLINE credentials (run `npm run activate` once to produce these)
TX_API_TOKEN=
TX_JWT=

# Operator service wallet (fee payer, market authority). JSON keypair path.
SERVICE_WALLET=./_keys/service-wallet.json

# Solana RPC (defaults to public devnet if unset)
# RPC_URL=

# Shared Postgres (same DATABASE_URL as web/)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bigshout

# World Cup competition id per TxODDS examples
COMPETITION_ID=72
